{
  "name": "topodraft-monorepo",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "TopoDraft — Network Topology as Code: a graphical network-topology editor for *.topo.json files (VSCode extension monorepo)",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "lint": "eslint .",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npm run test:e2e --workspace topodraft",
    "package": "npm run package --workspace topodraft"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.10.0",
    "@types/vscode": "^1.90.0",
    "@vitest/coverage-v8": "^3.2.6",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^3.9.2",
    "ajv": "^8.17.1",
    "esbuild": "^0.25.0",
    "eslint": "^9.20.0",
    "jsdom": "^25.0.0",
    "mocha": "^10.8.2",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.24.0",
    "vitest": "^3.2.0"
  },
  "overrides": {
    "serialize-javascript": "^7.0.7"
  }
}

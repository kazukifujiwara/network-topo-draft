{
  "name": "@topodraft/webview-ui",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Canvas UI for the Network TopoDraft custom editor (read-only viewer since Phase 1)",
  "exports": {
    ".": "./src/index.ts"
  },
  "types": "./src/index.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "esbuild src/main.ts --bundle --format=iife --outfile=dist/webview.js --log-level=warning"
  },
  "dependencies": {
    "@topodraft/core": "0.0.1",
    "@topodraft/protocol": "0.0.1"
  }
}

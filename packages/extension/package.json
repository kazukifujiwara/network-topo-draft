{
  "name": "topodraft",
  "displayName": "TopoDraft — Network Topology as Code",
  "version": "0.5.0",
  "license": "Apache-2.0",
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#0E1621",
    "theme": "dark"
  },
  "qna": false,
  "capabilities": {
    "virtualWorkspaces": true
  },
  "private": true,
  "publisher": "kazukifujiwara",
  "description": "%extension.description%",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "main": "./dist/extension.js",
  "browser": "./dist/extension-web.js",
  "l10n": "./l10n",
  "activationEvents": [],
  "contributes": {
    "customEditors": [
      {
        "viewType": "topodraft.editor",
        "displayName": "%editor.displayName%",
        "selector": [
          {
            "filenamePattern": "*.topo.json"
          },
          {
            "filenamePattern": "*.topo"
          }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "topodraft.newFile",
        "title": "%command.newFile%",
        "category": "TopoDraft"
      },
      {
        "command": "topodraft.openExample",
        "title": "%command.openExample%",
        "category": "TopoDraft"
      },
      {
        "command": "topodraft.saveAsTemplate",
        "title": "%command.saveAsTemplate%",
        "category": "TopoDraft"
      },
      {
        "command": "topodraft.writeAgentGuide",
        "title": "%command.writeAgentGuide%",
        "category": "TopoDraft"
      },
      {
        "command": "topodraft.writeNetboxGuide",
        "title": "%command.writeNetboxGuide%",
        "category": "TopoDraft"
      },
      {
        "command": "topodraft.validate",
        "title": "%command.validate%",
        "category": "TopoDraft"
      },
      {
        "command": "topodraft.exportMarkdown",
        "title": "%command.exportMarkdown%",
        "category": "TopoDraft"
      },
      {
        "command": "topodraft.exportForAi",
        "title": "%command.exportForAi%",
        "category": "TopoDraft"
      },
      {
        "command": "topodraft.exportSchema",
        "title": "%command.exportSchema%",
        "category": "TopoDraft"
      },
      {
        "command": "topodraft.exportDrawio",
        "title": "%command.exportDrawio%",
        "category": "TopoDraft"
      },
      {
        "command": "topodraft.exportSvg",
        "title": "%command.exportSvg%",
        "category": "TopoDraft"
      },
      {
        "command": "topodraft.exportPng",
        "title": "%command.exportPng%",
        "category": "TopoDraft"
      },
      {
        "command": "topodraft.openAsText",
        "title": "%command.openAsText%",
        "category": "TopoDraft",
        "icon": "$(code)"
      },
      {
        "command": "topodraft.openInTopologyEditor",
        "title": "%command.openInTopologyEditor%",
        "category": "TopoDraft",
        "icon": "$(circuit-board)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "topodraft.openAsText",
          "when": "activeCustomEditorId == topodraft.editor",
          "group": "navigation@1"
        },
        {
          "command": "topodraft.openInTopologyEditor",
          "when": "resourceFilename =~ /\\.topo\\.json$/ && activeCustomEditorId != topodraft.editor",
          "group": "navigation@1"
        }
      ]
    },
    "configuration": {
      "title": "TopoDraft",
      "properties": {
        "topodraft.templatesFolder": {
          "type": "string",
          "default": ".topodraft/templates",
          "description": "%config.templatesFolder%"
        },
        "topodraft.pngExportScale": {
          "type": "number",
          "default": 2,
          "minimum": 1,
          "maximum": 4,
          "description": "%config.pngExportScale%"
        }
      }
    },
    "jsonValidation": [
      {
        "fileMatch": "*.topo.json",
        "url": "./schema/topodraft.schema.json"
      },
      {
        "fileMatch": "*.topo",
        "url": "./schema/topodraft.schema.json"
      }
    ],
    "languages": [
      {
        "id": "json",
        "extensions": [
          ".topo"
        ]
      }
    ],
    "walkthroughs": [
      {
        "id": "topodraft.gettingStarted",
        "title": "%walkthrough.title%",
        "description": "%walkthrough.description%",
        "steps": [
          {
            "id": "openExample",
            "title": "%walkthrough.openExample.title%",
            "description": "%walkthrough.openExample.description%",
            "media": {
              "image": "media/walkthrough/example.png",
              "altText": "%walkthrough.openExample.alt%"
            },
            "completionEvents": [
              "onCommand:topodraft.openExample"
            ]
          },
          {
            "id": "draw",
            "title": "%walkthrough.draw.title%",
            "description": "%walkthrough.draw.description%",
            "media": {
              "svg": "media/walkthrough/draw.svg",
              "altText": "%walkthrough.draw.alt%"
            }
          },
          {
            "id": "newFile",
            "title": "%walkthrough.newFile.title%",
            "description": "%walkthrough.newFile.description%",
            "media": {
              "image": "media/walkthrough/logical.png",
              "altText": "%walkthrough.newFile.alt%"
            },
            "completionEvents": [
              "onCommand:topodraft.newFile"
            ]
          },
          {
            "id": "agentGuide",
            "title": "%walkthrough.agentGuide.title%",
            "description": "%walkthrough.agentGuide.description%",
            "media": {
              "svg": "media/walkthrough/agent.svg",
              "altText": "%walkthrough.agentGuide.alt%"
            },
            "completionEvents": [
              "onCommand:topodraft.writeAgentGuide"
            ]
          },
          {
            "id": "validate",
            "title": "%walkthrough.validate.title%",
            "description": "%walkthrough.validate.description%",
            "media": {
              "svg": "media/walkthrough/validate.svg",
              "altText": "%walkthrough.validate.alt%"
            },
            "completionEvents": [
              "onCommand:topodraft.validate"
            ]
          }
        ]
      }
    ]
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "node build.mjs",
    "test:e2e": "node build.mjs && node test-e2e/run.mjs",
    "package": "node build.mjs && vsce package --no-dependencies",
    "test:web": "node build.mjs && node test-web/run.mjs"
  },
  "dependencies": {
    "@topodraft/core": "0.0.1",
    "@topodraft/protocol": "0.0.1",
    "@topodraft/webview-ui": "0.0.1",
    "jsonc-parser": "^3.3.1"
  },
  "keywords": [
    "network",
    "topology",
    "network topology",
    "network diagram",
    "topology as code",
    "diagram as code",
    "netbox",
    "vrf",
    "draw.io"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/kazukifujiwara/network-topo-draft.git"
  },
  "bugs": {
    "url": "https://github.com/kazukifujiwara/network-topo-draft/issues"
  },
  "homepage": "https://github.com/kazukifujiwara/network-topo-draft#readme"
}

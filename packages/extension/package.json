{
  "name": "topodraft",
  "displayName": "Network TopoDraft",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Graphical network-topology editor for *.topo.json files (Phase 1+; empty shell in Phase 0)",
  "engines": {
    "vscode": "^1.90.0"
  },
  "main": "./dist/extension.js",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "esbuild src/extension.ts --bundle --platform=node --format=cjs --external:vscode --outfile=dist/extension.js --log-level=warning"
  },
  "dependencies": {
    "@topodraft/core": "0.0.1",
    "@topodraft/protocol": "0.0.1"
  }
}
